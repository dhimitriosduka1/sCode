    "configuration": {
      "title": "SLURM Cluster Manager",
      "properties": {
        "slurmClusterManager.autoRefreshInterval": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 3600,
          "description": "Auto refresh interval in seconds (5-3600)"
        },
        "slurmClusterManager.autoRefreshEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable auto refresh of job lists"
        },
        "slurmClusterManager.confirmCancelJob": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before cancelling a job"
        },
        "slurmClusterManager.mockMode": {
          "type": "boolean",
          "default": false,
          "description": "Use local mock Slurm data for extension development without requiring Slurm commands"
        },
        "slurmClusterManager.leaderboardTopUserCount": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Number of top GPU users to show in the Hall of Shame. Your own row is still shown when it falls outside this count."
        },
        "slurmClusterManager.submitDependencyBehavior": {
          "type": "string",
          "enum": [
            "prompt",
            "never"
          ],
          "default": "prompt",
          "description": "Whether to prompt for job dependencies when submitting a job (e.g. via the play button)"
        },
        "slurmClusterManager.showResourceHogs": {
          "type": "boolean",
          "default": true,
          "description": "Whether to fetch and display the Job Hog and GPU Gobbler stats at the top of the active jobs list."
        },
        "slurmClusterManager.openOutputAsPreview": {
          "type": "boolean",
          "default": false,
          "description": "Open stdout/stderr logs in preview mode (meaning clicking another file replaces the current tab)."
        },
        "slurmClusterManager.scrollToBottom": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scroll to the bottom (tail) of the file when opening stdout or stderr logs."
        }
      }
    }
