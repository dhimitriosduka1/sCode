{
  "name": "slurm-cluster-manager",
  "displayName": "SLURM Cluster Manager",
  "description": "Manage and monitor SLURM cluster jobs directly from VSCode",
  "version": "1.6.53",
  "icon": "icon.png",
  "publisher": "DhimitriosDuka",
  "license": "MIT",
  "keywords": [
    "slurm",
    "hpc",
    "cluster",
    "jobs",
    "batch",
    "scheduler",
    "gpu",
    "compute",
    "queue",
    "workload"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dhimitriosduka1/sCode"
  },
  "homepage": "https://github.com/dhimitriosduka1/sCode#readme",
  "bugs": {
    "url": "https://github.com/dhimitriosduka1/sCode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
