{
  "name": "slurm-cluster-manager",
  "displayName": "SLURM Cluster Manager",
  "description": "Manage and monitor SLURM cluster jobs directly from VSCode",
  "version": "1.4.0",
  "icon": "icon.png",
  "publisher": "DhimitriosDuka",
  "license": "MIT",
  "keywords": [
    "slurm",
    "hpc",
    "cluster",
    "jobs",
    "batch",
    "scheduler",
    "gpu",
    "compute",
    "queue",
    "workload"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dhimitriosduka1/sCode"
  },
  "homepage": "https://github.com/dhimitriosduka1/sCode#readme",
  "bugs": {
    "url": "https://github.com/dhimitriosduka1/sCode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Machine Learning",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "slurm-explorer",
          "title": "SLURM Cluster",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "slurm-explorer": [
        {
          "id": "slurmPartitionUsage",
          "name": "GPU Partition Usage",
          "icon": "$(server-process)",
          "contextualTitle": "SLURM GPU Partition Usage"
        },
        {
          "id": "slurmClusterOverview",
          "name": "Cluster Overview",
          "icon": "$(dashboard)",
          "contextualTitle": "SLURM Cluster Overview"
        },
        {
          "id": "slurmLeaderboard",
          "name": "Hall of Shame",
          "icon": "$(flame)",
          "contextualTitle": "SLURM Hall of Shame"
        },
        {
          "id": "slurmJobs",
          "name": "Active Jobs",
          "icon": "$(tasklist)",
          "contextualTitle": "SLURM Active Jobs"
        },
        {
          "id": "slurmHistory",
          "name": "Job History",
          "icon": "$(history)",
          "contextualTitle": "SLURM Job History"
        }
      ]
    },
    "commands": [
      {
        "command": "slurmPartitionUsage.refresh",
        "title": "Refresh GPU Partition Usage",
        "icon": "$(refresh)"
      },
      {
        "command": "slurmClusterOverview.refresh",
        "title": "Refresh Cluster Overview",
        "icon": "$(refresh)"
      },
      {
        "command": "slurmJobs.refresh",
        "title": "Refresh Jobs",
        "icon": "$(refresh)"
      },
      {
        "command": "slurmHistory.refresh",
        "title": "Refresh Job History",
        "icon": "$(refresh)"
      },
      {
        "command": "slurmHistory.setRange",
        "title": "Set Job History Range",
        "icon": "$(calendar)"
      },
      {
        "command": "slurmJobs.search",
        "title": "Search Jobs",
        "icon": "$(search)"
      },
      {
        "command": "slurmJobs.clearSearch",
        "title": "Clear Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "slurmJobs.openFile",
        "title": "Open File"
      },
      {
        "command": "slurmJobs.openStdout",
        "title": "Open Stdout",
        "icon": "$(output)"
      },
      {
        "command": "slurmJobs.openStderr",
        "title": "Open Stderr",
        "icon": "$(warning)"
      },
      {
        "command": "slurmJobs.toggleAutoRefresh",
        "title": "Toggle Auto Refresh",
        "icon": "$(sync)"
      },
      {
        "command": "slurmJobs.setAutoRefreshInterval",
        "title": "Set Auto Refresh Interval"
      },
      {
        "command": "slurmJobs.cancelJob",
        "title": "Cancel Job",
        "icon": "$(trash)"
      },
      {
        "command": "slurmJobs.cancelAllJobs",
        "title": "Cancel All Jobs",
        "icon": "$(trash)"
      },
      {
        "command": "slurmJobs.cancelAllPendingJobs",
        "title": "Cancel All Pending Jobs",
        "icon": "$(trash)"
      },
      {
        "command": "slurmHistory.search",
        "title": "Search Job History",
        "icon": "$(search)"
      },
      {
        "command": "slurmHistory.clearSearch",
        "title": "Clear Job History Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "slurmHistory.nextPage",
        "title": "Next Job History Page",
        "icon": "$(chevron-right)"
      },
      {
        "command": "slurmHistory.previousPage",
        "title": "Previous Job History Page",
        "icon": "$(chevron-left)"
      },
      {
        "command": "slurmJobs.submitJob",
        "title": "Submit Job",
        "icon": "$(play)"
      },
      {
        "command": "slurmJobs.pinJob",
        "title": "Pin Job",
        "icon": "$(pin)"
      },
      {
        "command": "slurmJobs.unpinJob",
        "title": "Unpin Job",
        "icon": "$(pinned)"
      },
      {
        "command": "slurmLeaderboard.refresh",
        "title": "Refresh Hall of Shame",
        "icon": "$(refresh)"
      },
      {
        "command": "slurmLeaderboard.setTopUserCount",
        "title": "Set Hall of Shame Size",
        "icon": "$(list-ordered)"
      },
      {
        "command": "slurmJobs.submitCurrentFile",
        "title": "Submit to SLURM",
        "icon": "$(play)"
      },
      {
        "command": "slurmRemote.configure",
        "title": "Connect to SLURM Cluster",
        "icon": "$(settings-gear)"
      },
      {
        "command": "slurmRemote.switchCluster",
        "title": "Switch SLURM Cluster",
        "icon": "$(server-environment)"
      },
      {
        "command": "slurmRemote.testConnection",
        "title": "Test SLURM Connection",
        "icon": "$(plug)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "slurmJobs.submitCurrentFile",
          "when": "slurmJobs.isSlurmScript",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "slurmPartitionUsage.refresh",
          "when": "view == slurmPartitionUsage",
          "group": "navigation@1"
        },
        {
          "command": "slurmClusterOverview.refresh",
          "when": "view == slurmClusterOverview",
          "group": "navigation@1"
        },
        {
          "command": "slurmJobs.refresh",
          "when": "view == slurmJobs",
          "group": "navigation@1"
        },
        {
          "command": "slurmJobs.search",
          "when": "view == slurmJobs",
          "group": "navigation@2"
        },
        {
          "command": "slurmJobs.clearSearch",
          "when": "view == slurmJobs",
          "group": "navigation@3"
        },
        {
          "command": "slurmJobs.toggleAutoRefresh",
          "when": "view == slurmJobs",
          "group": "navigation@4"
        },
        {
          "command": "slurmJobs.submitJob",
          "when": "view == slurmJobs",
          "group": "navigation@5"
        },
        {
          "command": "slurmJobs.cancelAllJobs",
          "when": "view == slurmJobs",
          "group": "navigation@6"
        },
        {
          "command": "slurmHistory.refresh",
          "when": "view == slurmHistory",
          "group": "navigation@1"
        },
        {
          "command": "slurmHistory.search",
          "when": "view == slurmHistory",
          "group": "navigation@3"
        },
        {
          "command": "slurmHistory.clearSearch",
          "when": "view == slurmHistory",
          "group": "navigation@4"
        },
        {
          "command": "slurmHistory.previousPage",
          "when": "view == slurmHistory",
          "group": "navigation@5"
        },
        {
          "command": "slurmHistory.nextPage",
          "when": "view == slurmHistory",
          "group": "navigation@6"
        },
        {
          "command": "slurmHistory.setRange",
          "when": "view == slurmHistory",
          "group": "navigation@2"
        },
        {
          "command": "slurmLeaderboard.refresh",
          "when": "view == slurmLeaderboard",
          "group": "navigation@1"
        },
        {
          "command": "slurmLeaderboard.setTopUserCount",
          "when": "view == slurmLeaderboard",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "slurmJobs.cancelAllPendingJobs",
          "when": "view == slurmJobs && viewItem == statusCategoryPending",
          "group": "inline@1"
        },
        {
          "command": "slurmJobs.openStdout",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "inline@1"
        },
        {
          "command": "slurmJobs.openStderr",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "inline@2"
        },
        {
          "command": "slurmJobs.openStdout",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "output@1"
        },
        {
          "command": "slurmJobs.openStderr",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "output@2"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "inline@3"
        },
        {
          "command": "slurmJobs.pinJob",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "inline@4"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "actions@1"
        },
        {
          "command": "slurmJobs.pinJob",
          "when": "view == slurmJobs && viewItem == slurmJob",
          "group": "actions@2"
        },
        {
          "command": "slurmJobs.openStdout",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "inline@1"
        },
        {
          "command": "slurmJobs.openStderr",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "inline@2"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "inline@3"
        },
        {
          "command": "slurmJobs.unpinJob",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "inline@4"
        },
        {
          "command": "slurmJobs.openStdout",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "output@1"
        },
        {
          "command": "slurmJobs.openStderr",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "output@2"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "actions@1"
        },
        {
          "command": "slurmJobs.unpinJob",
          "when": "view == slurmJobs && viewItem == slurmJobPinned",
          "group": "actions@2"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJobPending",
          "group": "inline@1"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJobPending",
          "group": "actions@1"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJobPendingPinned",
          "group": "inline@1"
        },
        {
          "command": "slurmJobs.cancelJob",
          "when": "view == slurmJobs && viewItem == slurmJobPendingPinned",
          "group": "actions@1"
        }
      ]
    },
    "configuration": {
      "title": "SLURM Cluster Manager",
      "properties": {
        "slurmClusterManager.autoRefreshInterval": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 3600,
          "description": "Auto refresh interval in seconds (5-3600)"
        },
        "slurmClusterManager.autoRefreshEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable auto refresh of job lists"
        },
        "slurmClusterManager.confirmCancelJob": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before cancelling a job"
        },
        "slurmClusterManager.connectionMode": {
          "type": "string",
          "default": "local",
          "enum": [
            "local",
            "ssh"
          ],
          "enumDescriptions": [
            "Run Slurm commands on the same machine as the extension host.",
            "Run Slurm commands on a remote server through the local OpenSSH client."
          ],
          "description": "Where SLURM commands should be executed"
        },
        "slurmClusterManager.sshHost": {
          "type": "string",
          "default": "",
          "description": "OpenSSH host alias or user@host value used when connectionMode is ssh. Authentication uses your existing SSH keys or agent."
        },
        "slurmClusterManager.activeCluster": {
          "type": "string",
          "default": "",
          "description": "Name of the active SLURM cluster profile. Use \"local\" for local mode. Empty falls back to the legacy connectionMode/sshHost settings."
        },
        "slurmClusterManager.clusters": {
          "type": "array",
          "default": [],
          "description": "Named SLURM cluster connection profiles. SSH profiles use OpenSSH host aliases or user@host values and never store passwords.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "connectionMode"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this cluster profile"
              },
              "connectionMode": {
                "type": "string",
                "enum": [
                  "local",
                  "ssh"
                ],
                "description": "Where Slurm commands should be executed for this profile"
              },
              "sshHost": {
                "type": "string",
                "description": "OpenSSH host alias or user@host value for SSH profiles"
              },
              "sshConnectTimeout": {
                "type": "number",
                "minimum": 1,
                "maximum": 120,
                "description": "SSH connection timeout in seconds for this profile"
              },
              "remoteLogMaxBytes": {
                "type": "number",
                "minimum": 1024,
                "description": "Maximum remote stdout/stderr file size to open through SSH for this profile"
              }
            }
          }
        },
        "slurmClusterManager.sshConnectTimeout": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 120,
          "description": "SSH connection timeout in seconds when connectionMode is ssh"
        },
        "slurmClusterManager.remoteLogMaxBytes": {
          "type": "number",
          "default": 2097152,
          "minimum": 1024,
          "description": "Maximum remote stdout/stderr file size to open through SSH, in bytes"
        },
        "slurmClusterManager.mockMode": {
          "type": "boolean",
          "default": false,
          "description": "Use local mock Slurm data for extension development without requiring Slurm commands"
        },
        "slurmClusterManager.leaderboardTopUserCount": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Number of top GPU users to show in the Hall of Shame. Your own row is still shown when it falls outside this count."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test out/test/*.test.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  }
}
